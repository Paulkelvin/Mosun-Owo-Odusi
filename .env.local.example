# ==============================================================================
# MOSUN OWO-ODUSI WEBSITE - ENVIRONMENT VARIABLES
# ==============================================================================

# ------------------------------------------------------------------------------
# Sanity CMS (REQUIRED)
# ------------------------------------------------------------------------------
# Find these in https://www.sanity.io/manage -> your project -> API
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Write token with Editor (or higher) role. Required ONLY for seeding/mutations
# (e.g. running scripts/seed.ts). Not needed to read published content. Keep secret.
SANITY_API_WRITE_TOKEN=

# ------------------------------------------------------------------------------
# Email — contact & about forms (REQUIRED for those forms to send)
# ------------------------------------------------------------------------------
# Resend API key: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=contact@yourdomain.com
TO_EMAIL=you@yourdomain.com

# ==============================================================================
# SETUP
# ==============================================================================
# 1. Copy this file to .env.local and fill in the values.
# 2. Seed content into Sanity (one-time / when re-seeding):
#      npx tsx scripts/seed.ts
# 3. Run the site + Studio:
#      npm run dev   ->   http://localhost:3000  and  http://localhost:3000/studio
#
# On Vercel, add the NEXT_PUBLIC_SANITY_* and RESEND_* vars in Project Settings.
# The write token is only needed locally for seeding, not for the deployed site.
# ==============================================================================
